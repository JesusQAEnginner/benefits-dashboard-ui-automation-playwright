{
  "name": "benefits-dashboard-ui-automation-playwright",
  "version": "1.0.0",
  "description": "UI automation framework for the Benefits Dashboard using Playwright (JavaScript).",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
  "test:setup:headed": "playwright test tests/setup/login.setup.spec.js --project=setup --headed",
  "test:setup": "playwright test tests/setup/login.setup.spec.js --project=setup",
  "test:ui:headed": "playwright test --project=chromium --headed",
  "test:ui": "playwright test --project=chromium",
  "test:smoke": "playwright test --project=chromium --grep \"@smoke\"",
  "report": "playwright show-report"
},
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JesusQAEnginner/benefits-dashboard-ui-automation-playwright.git"
  },
