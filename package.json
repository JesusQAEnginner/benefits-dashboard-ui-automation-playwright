  },
  "homepage": "https://github.com/JesusQAEnginner/benefits-dashboard-ui-automation-playwright#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.0",
    "dotenv": "^17.3.1"
  }
}